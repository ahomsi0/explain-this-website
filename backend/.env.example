# Server
PORT=8080
ALLOWED_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
FETCH_TIMEOUT_SEC=60
MAX_BODY_BYTES=5242880
APP_URL=http://localhost:5173

# Database (required)
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable

# Auth (required)
JWT_SECRET=change-me-to-a-long-random-secret

# Admin (optional — if unset, only homsiahmed16@gmail.com can perform admin actions)
ADMIN_EMAIL=

# PageSpeed (optional — leave empty to skip performance analysis)
PAGESPEED_API_KEY=

# Email / Resend (required for password reset and broadcasts)
RESEND_API_KEY=
FROM_EMAIL=noreply@explainthewebsite.com

# Tap Payments
TAP_SECRET_KEY=
TAP_MONTHLY_PLAN_ID=
TAP_YEARLY_PLAN_ID=
TAP_WEBHOOK_SECRET=
